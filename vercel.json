{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install",
  "buildCommand": "pnpm --filter @workspace/api-server run build:handler && BASE_PATH=/ pnpm --filter @workspace/vcf-app run build",
  "outputDirectory": "artifacts/vcf-app/dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
